# Server
PORT=3300
HOST=0.0.0.0
NODE_ENV=development

# Database
DB_PATH=./data/uptime-detective.db

# Auth
JWT_SECRET=change-me-to-a-random-string
SESSION_EXPIRY=7d

# Monitoring
ALLOW_PRIVATE_IPS=true    # Set to true to monitor private/internal IPs (e.g. 192.168.x, 10.x)

# Optional: SMTP for email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
